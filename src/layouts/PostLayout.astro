---
import '@/styles/global.css'
import type { PostLayoutProps } from '@/types'
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import FootnoteScroll from '@/components/widgets/FootnoteScroll.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Footer from '@/components/layout/Footer.astro'
import BackButton from '@/components/ui/BackButton.astro'
import TableOfContents from '@/components/ui/TableOfContents.astro'
import PostShare from '@/components/ui/PostShare.astro'
import GradientMask from '@/components/ui/GradientMask.astro'
import ImageOptimizer from '@/components/ui/ImageOptimizer.astro'
import ImageViewer from '@/components/ui/ImageViewer.astro'
import GitHubCard from '@/components/ui/GitHubCard.astro'
import NeoDBCard from '@/components/ui/NeoDBCard.astro'
import XPOST from '@/components/ui/XPOST.astro'
import CopyCode from '@/components/ui/CopyCode.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { renderInlineMarkdown, stripInlineMarkdown } from '@/utils/inline-markdown'

import { themeConfig } from '@/config'

const { title, pubDate, readingTime, toc } = Astro.props as PostLayoutProps
const plainTitle = stripInlineMarkdown(title)

const postSlug = Astro.url.pathname.split('/').filter(Boolean).pop() || ''
const postUrl = new URL(Astro.url.pathname, Astro.site ?? new URL(themeConfig.site.website)).toString()
const ogImageVersion = pubDate.toISOString().slice(0, 10).replaceAll('-', '')
const ogImage = `/open-graph/${postSlug}.png?v=${ogImageVersion}`
---

<BaseLayout title={`${plainTitle} · ${themeConfig.site.title}`} description={themeConfig.site.description} type="post">
  <BaseHead
    title={`${plainTitle} · ${themeConfig.site.title}`}
    description={themeConfig.site.description}
    ogImage={ogImage}
    slot="head"
  />
  <div class="post-container">
    <main>
      <div class="prose">
        <GradientMask />
        <BackButton href="/writing/" label="writing" />
        {themeConfig.post.toc && <TableOfContents toc={toc} />}
        <div class="title">
          <h1 set:html={renderInlineMarkdown(title)} />
          <div class="date">
            <FormattedDate date={pubDate} context="post" />
            {
              themeConfig.post.readingTime && readingTime && (
                <span class="reading-time">
                  <span class="separator">·</span>
                  {readingTime.text}
                </span>
              )
            }
          </div>
          <PostShare title={plainTitle} url={postUrl} />
        </div>
        <article class="content">
          <slot />
        </article>
      </div>
    </main>
    <ImageOptimizer />
    <FootnoteScroll />
    <CopyCode />
    <GitHubCard />
    <XPOST />
    <NeoDBCard />
    {themeConfig.post.imageViewer && <ImageViewer />}
    {themeConfig.general.footer && <Footer />}
  </div>
  <div id="diagram-viewer" class="diagram-viewer" aria-hidden="true">
    <button class="diagram-viewer-close" type="button" aria-label="Close expanded diagram"></button>
    <div class="diagram-viewer-surface">
      <img id="diagram-viewer-img" src="" alt="Expanded diagram" />
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', async () => {
    const expandIcon = `
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M1.75 1A.75.75 0 0 0 1 1.75v4.5a.75.75 0 0 0 1.5 0V3.56l3.22 3.22a.75.75 0 0 0 1.06-1.06L3.56 2.5h2.69a.75.75 0 0 0 0-1.5h-4.5Zm7.47 8.22a.75.75 0 0 1 1.06 0l3.22 3.22V9.75a.75.75 0 0 1 1.5 0v4.5a.75.75 0 0 1-.75.75h-4.5a.75.75 0 0 1 0-1.5h2.69l-3.22-3.22a.75.75 0 0 1 0-1.06Z"></path>
      </svg>
    `
    const copyIcon = `
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"></path>
        <path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"></path>
      </svg>
    `
    const copiedIcon = `
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"></path>
      </svg>
    `
    const mermaidThemeCSS = `
      .node rect,
      .node circle,
      .node ellipse,
      .node polygon,
      .node path {
        fill: var(--mermaid-node-bg) !important;
        stroke: var(--mermaid-node-border) !important;
        stroke-width: 1.25px !important;
      }

      .nodeLabel,
      .nodeLabel p,
      .label,
      .label text,
      .label span,
      .cluster-label text,
      .cluster-label span {
        color: var(--mermaid-node-text) !important;
        fill: var(--mermaid-node-text) !important;
      }

      .edgePath .path,
      path.flowchart-link,
      .flowchart-link {
        stroke: var(--mermaid-edge) !important;
        stroke-width: 1.25px !important;
      }

      .arrowheadPath {
        fill: var(--mermaid-edge) !important;
        stroke: var(--mermaid-edge) !important;
      }

      .edgeLabel,
      .edgeLabel p,
      .edgeLabel rect,
      .labelBkg {
        background: var(--mermaid-label-bg) !important;
        fill: var(--mermaid-label-bg) !important;
      }

      .cluster rect {
        fill: transparent !important;
        stroke: var(--mermaid-node-border) !important;
      }
    `
    const mermaidCSSVariables = [
      '--mermaid-node-bg',
      '--mermaid-node-border',
      '--mermaid-node-text',
      '--mermaid-edge',
      '--mermaid-label-bg'
    ]

    const getMermaidTheme = () => {
      const style = getComputedStyle(document.documentElement)
      const getColor = (name, fallback) => style.getPropertyValue(name).trim() || fallback
      const bg = getColor('--bg', '#ffffff')
      const codeBg = getColor('--code-bg', 'rgba(0, 0, 0, 0.04)')
      const textPrimary = getColor('--text-primary', 'rgba(0, 0, 0, 0.85)')
      const textTertiary = getColor('--text-tertiary', 'rgba(0, 0, 0, 0.24)')
      const border = getColor('--border', 'rgba(0, 0, 0, 0.1)')

      return {
        startOnLoad: false,
        theme: 'base',
        themeCSS: mermaidThemeCSS,
        themeVariables: {
          background: bg,
          primaryColor: codeBg,
          primaryTextColor: textPrimary,
          primaryBorderColor: border,
          lineColor: textTertiary,
          secondaryColor: codeBg,
          tertiaryColor: bg,
          edgeLabelBackground: bg,
          mainBkg: codeBg,
          nodeBorder: border,
          clusterBkg: bg,
          clusterBorder: border,
          titleColor: textPrimary,
          fontFamily: getColor('--sans', 'Inter, sans-serif'),
          fontSize: '15px',
          darkMode: document.documentElement.classList.contains('dark')
        }
      }
    }

    const cloneDiagramSvg = (svg) => {
      const clone = svg.cloneNode(true)
      const diagram = svg.closest('.mermaid')
      const style = getComputedStyle(diagram || document.documentElement)

      mermaidCSSVariables.forEach((name) => {
        const value = style.getPropertyValue(name).trim()
        if (value) clone.style.setProperty(name, value)
      })

      return clone
    }

    const viewer = document.getElementById('diagram-viewer')
    const viewerImg = document.getElementById('diagram-viewer-img')
    const viewerClose = viewer?.querySelector('.diagram-viewer-close')

    const hideDiagram = () => {
      if (!viewer || !(viewerImg instanceof HTMLImageElement)) return
      viewer.classList.remove('active')
      viewer.setAttribute('aria-hidden', 'true')
      document.body.classList.remove('diagram-viewer-open')
      document.body.style.overflow = ''
      viewerImg.src = ''
    }

    const showDiagram = (svg) => {
      if (!viewer || !(viewerImg instanceof HTMLImageElement)) return
      const source = new XMLSerializer().serializeToString(cloneDiagramSvg(svg))
      viewerImg.src = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(source)}`
      viewer.classList.add('active')
      viewer.setAttribute('aria-hidden', 'false')
      document.body.classList.add('diagram-viewer-open')
      document.body.style.overflow = 'hidden'
    }

    const copyText = async (text, button) => {
      if (!text) return

      try {
        await navigator.clipboard.writeText(text)
      } catch (error) {
        console.error('Failed to copy Mermaid source:', error)
        return
      }

      button.innerHTML = copiedIcon
      window.setTimeout(() => {
        button.innerHTML = copyIcon
      }, 1500)
    }

    const bindDiagramControls = () => {
      document.querySelectorAll('.mermaid').forEach((diagram) => {
        if (diagram.dataset.diagramControlsBound) return
        const svg = diagram.querySelector('svg')
        if (!svg) return

        diagram.dataset.diagramControlsBound = 'true'

        const controls = document.createElement('div')
        controls.className = 'mermaid-actions'

        const copyButton = document.createElement('button')
        copyButton.className = 'mermaid-action-button mermaid-copy-button'
        copyButton.type = 'button'
        copyButton.setAttribute('aria-label', 'Copy Mermaid source')
        copyButton.title = 'Copy Mermaid source'
        copyButton.innerHTML = copyIcon
        copyButton.addEventListener('click', (event) => {
          event.preventDefault()
          event.stopPropagation()
          copyText(diagram.dataset.diagramSource || '', copyButton)
        })

        const expandButton = document.createElement('button')
        expandButton.className = 'mermaid-action-button mermaid-expand-button'
        expandButton.type = 'button'
        expandButton.setAttribute('aria-label', 'Expand diagram')
        expandButton.title = 'Expand diagram'
        expandButton.innerHTML = expandIcon
        expandButton.addEventListener('click', (event) => {
          event.preventDefault()
          event.stopPropagation()
          showDiagram(svg)
        })

        controls.append(copyButton, expandButton)
        diagram.append(controls)
      })
    }

    if (viewer && !viewer.dataset.diagramViewerInitialized) {
      viewer.dataset.diagramViewerInitialized = 'true'
      viewer.addEventListener('click', hideDiagram)
      viewerClose?.addEventListener('click', hideDiagram)
      viewer.querySelector('.diagram-viewer-surface')?.addEventListener('click', (event) => {
        event.stopPropagation()
      })
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && viewer.classList.contains('active')) {
          hideDiagram()
        }
      })
    }

    const blocks = document.querySelectorAll('pre[data-language="mermaid"]')
    if (blocks.length === 0) {
      bindDiagramControls()
      return
    }
    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
    mermaid.initialize(getMermaidTheme())
    for (const block of blocks) {
      const code = block.querySelector('code')?.textContent || ''
      const wrapper = document.createElement('div')
      wrapper.classList.add('mermaid')
      wrapper.dataset.diagramSource = code
      wrapper.textContent = code

      const copyWrapper = block.closest('.copy-code-wrapper')
      if (copyWrapper && copyWrapper.querySelector('pre[data-language="mermaid"]') === block) {
        copyWrapper.replaceWith(wrapper)
      } else {
        block.replaceWith(wrapper)
      }
    }
    await mermaid.run({ nodes: document.querySelectorAll('.mermaid') })
    bindDiagramControls()
  })
</script>

<style>
  .post-container {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-container main {
    flex: 1;
  }
</style>
