---
const links = [
  {
    label: 'GitHub',
    href: 'https://github.com/kaanbiryol',
    external: true,
    icon: 'github'
  },
  {
    label: 'X',
    href: 'https://x.com/kaanbiryol',
    external: true,
    icon: 'x'
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/kaan-biryol',
    external: true,
    icon: 'linkedin'
  }
]
---

<section class="contact-links" aria-label="Contact links">
  <nav>
    {
      links.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          aria-label={link.label}
          title={link.label}
        >
          {
            link.icon === 'github' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.08 1.85 1.24 1.85 1.24 1.07 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"
                />
              </svg>
            )
          }
          {
            link.icon === 'linkedin' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V8.99h3.41v1.57h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.42a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.03H3.54V8.99H7.1v11.46ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z"
                />
              </svg>
            )
          }
          {
            link.icon === 'x' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.5h2.04L6.48 3.23H4.29l13.32 17.42Z"
                />
              </svg>
            )
          }
          <span class="sr-only">{link.label}</span>
        </a>
      ))
    }
  </nav>
</section>

<style>
  .contact-links {
    margin: 0.1rem 0 0;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  a {
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-secondary);
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    text-decoration: none;
    transition:
      border-color 0.2s ease-out,
      color 0.2s ease-out,
      background-color 0.2s ease-out;
    width: 2rem;
  }

  a:hover,
  a:focus-visible {
    background-color: var(--selection);
    border-color: var(--text-tertiary);
    color: var(--text-primary);
  }

  svg {
    height: 1rem;
    width: 1rem;
  }

  @media (max-width: 768px) {
    .contact-links {
      margin-top: 0.1rem;
    }
  }
</style>
