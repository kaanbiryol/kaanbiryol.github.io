---
import FormattedDate from '@/components/widgets/FormattedDate.astro'
import type { PostListProps } from '@/types'
import { renderInlineMarkdown } from '@/utils/inline-markdown'

const { posts, bottomSpace = true } = Astro.props as PostListProps

const stripMarkdown = (text: string) =>
  text
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_#>~]/g, '')
    .replace(/\s+/g, ' ')
    .trim()

const trimExcerpt = (text: string, maxLength = 150) => {
  if (text.length <= maxLength) return text

  const trimmed = text.slice(0, maxLength - 3).replace(/\s+\S*$/, '')
  return `${trimmed}...`
}

const getExcerpt = (body?: string) => {
  const paragraph = (body ?? '')
    .split(/\n{2,}/)
    .map((block) => block.trim())
    .find((block) => block && !block.startsWith('```') && !block.startsWith('#') && !block.startsWith('- '))

  return paragraph ? trimExcerpt(stripMarkdown(paragraph)) : ''
}
---

<ul>
  {
    posts.map((post) => {
      const description = post.data.description ?? getExcerpt(post.body)

      return (
        <li>
          <a href={`/${post.id}/`}>
            <article class="post-item">
              <div class="post-copy">
                <h3 class="title" set:html={renderInlineMarkdown(post.data.title)} />
                {description && <p class="description" set:html={renderInlineMarkdown(description)} />}
              </div>
              <p class="date font-features">
                <FormattedDate date={post.data.pubDate} context="list" />
              </p>
            </article>
          </a>
        </li>
      )
    })
  }
</ul>
{bottomSpace && <div class="placeholder" />}

<style>
  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
  }

  li {
    border-top: 1px solid var(--border);
  }

  li:first-child {
    border-top: 0;
  }

  li:last-child {
    border-bottom: 1px solid var(--border);
  }

  a {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover a {
      opacity: 0.4;
    }

    ul:hover a:hover {
      opacity: 1;
    }
  }

  .post-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    padding: 0.95rem 0;
  }

  .title {
    font-size: var(--font-size-m);
    font-weight: var(--font-weight-bold);
    line-height: 1.55;
    margin: 0;
  }

  .description {
    color: var(--text-secondary);
    font-size: var(--font-size-s);
    line-height: 1.6;
    margin: 0.25rem 0 0;
  }

  .title :global(code),
  .description :global(code) {
    padding: 1.5px 3px;
    border-radius: 4px;
    background-color: var(--code-bg);
    border: 0.5px solid var(--border);
    font-family: var(--mono);
    font-size: 0.9em;
    font-weight: inherit;
    font-feature-settings:
      'liga' 0,
      'calt' 0;
  }

  .date {
    margin: 0.1rem 0 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: var(--spacing-s);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .placeholder {
    height: 3rem;
  }

  @media (max-width: 620px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .date {
      margin-top: 0;
    }
  }
</style>
