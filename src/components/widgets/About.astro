---
import { getEntry } from 'astro:content'

const aboutEntry = await getEntry('about', 'about')
// Check if there is actual content (excluding comments)
const hasContent = aboutEntry?.body ? aboutEntry.body.replace(/<!--[\s\S]*?-->/g, '').trim().length > 0 : false
const aboutHtml = hasContent && aboutEntry ? aboutEntry.rendered?.html : null
---

{hasContent && aboutHtml && <div class="about prose" set:html={aboutHtml} />}

<style>
  .about:not(:empty) {
    margin-bottom: 1.25rem;
  }

  .about.prose {
    margin-bottom: 0;
  }
</style>
